{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "df-elprisprojekt"
		},
		"ls_db_elprisprojekt_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'ls_db_elprisprojekt'"
		},
		"ls_elprisdatalake_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'ls_elprisdatalake'"
		},
		"ls_db_elprisprojekt_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "elprisprojekt.database.windows.net"
		},
		"ls_db_elprisprojekt_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "db-elprisprojekt"
		},
		"ls_db_elprisprojekt_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "sqladmin"
		},
		"ls_elprisdatalake_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://elprisdatalake.dfs.core.windows.net/"
		},
		"ls_prices_api_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://www.elprisetjustnu.se/api/v1/prices/"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "[concat(parameters('factoryName'), '/pl_backfill_load')]",
			"type": "Microsoft.DataFactory/factories/pipelines",
			"apiVersion": "2018-06-01",
			"properties": {
				"activities": [
					{
						"name": "backfill_insert_into_bronze",
						"type": "Copy",
						"dependsOn": [],
						"policy": {
							"timeout": "0.12:00:00",
							"retry": 0,
							"retryIntervalInSeconds": 30,
							"secureOutput": false,
							"secureInput": false
						},
						"userProperties": [],
						"typeProperties": {
							"source": {
								"type": "JsonSource",
								"additionalColumns": [
									{
										"name": "source_file",
										"value": "$$FILENAME"
									}
								],
								"storeSettings": {
									"type": "AzureBlobFSReadSettings",
									"recursive": true,
									"wildcardFolderPath": {
										"value": "raw/elpriser/backfill",
										"type": "Expression"
									},
									"wildcardFileName": "*",
									"enablePartitionDiscovery": false
								},
								"formatSettings": {
									"type": "JsonReadSettings"
								}
							},
							"sink": {
								"type": "AzureSqlSink",
								"writeBehavior": "insert",
								"sqlWriterUseTableLock": false
							},
							"enableStaging": false,
							"translator": {
								"type": "TabularTranslator",
								"mappings": [
									{
										"source": {
											"path": "$['SEK_per_kWh']"
										},
										"sink": {
											"name": "sek_per_kwh",
											"type": "Decimal"
										}
									},
									{
										"source": {
											"path": "$['EUR_per_kWh']"
										},
										"sink": {
											"name": "eur_per_kwh",
											"type": "Decimal"
										}
									},
									{
										"source": {
											"path": "$['EXR']"
										},
										"sink": {
											"name": "exr",
											"type": "Decimal"
										}
									},
									{
										"source": {
											"path": "$['time_start']"
										},
										"sink": {
											"name": "time_start",
											"type": "DateTimeOffset"
										}
									},
									{
										"source": {
											"path": "$['time_end']"
										},
										"sink": {
											"name": "time_end",
											"type": "DateTimeOffset"
										}
									},
									{
										"source": {
											"path": "$['source_file']"
										},
										"sink": {
											"name": "source_file",
											"type": "String"
										}
									}
								]
							}
						},
						"inputs": [
							{
								"referenceName": "ds_datalake_prices_backfill",
								"type": "DatasetReference",
								"parameters": {}
							}
						],
						"outputs": [
							{
								"referenceName": "ds_sql_bronze_load",
								"type": "DatasetReference",
								"parameters": {}
							}
						]
					}
				],
				"policy": {
					"elapsedTimeMetric": {}
				},
				"annotations": []
			},
			"dependsOn": [
				"[concat(variables('factoryId'), '/datasets/ds_datalake_prices_backfill')]",
				"[concat(variables('factoryId'), '/datasets/ds_sql_bronze_load')]"
			]
		},
		{
			"name": "[concat(parameters('factoryName'), '/pl_delete_old_prices_in_bronze')]",
			"type": "Microsoft.DataFactory/factories/pipelines",
			"apiVersion": "2018-06-01",
			"properties": {
				"activities": [
					{
						"name": "delete_old_prices_in_bronze",
						"description": "Tar bort rader äldre än 3 dagar",
						"type": "SqlServerStoredProcedure",
						"dependsOn": [],
						"policy": {
							"timeout": "0.12:00:00",
							"retry": 0,
							"retryIntervalInSeconds": 30,
							"secureOutput": false,
							"secureInput": false
						},
						"userProperties": [],
						"typeProperties": {
							"storedProcedureName": "[[bronze].[delete_old_prices_bronze]"
						},
						"linkedServiceName": {
							"referenceName": "ls_db_elprisprojekt",
							"type": "LinkedServiceReference"
						}
					}
				],
				"policy": {
					"elapsedTimeMetric": {}
				},
				"annotations": []
			},
			"dependsOn": [
				"[concat(variables('factoryId'), '/linkedServices/ls_db_elprisprojekt')]"
			]
		},
		{
			"name": "[concat(parameters('factoryName'), '/pl_ingest_prices')]",
			"type": "Microsoft.DataFactory/factories/pipelines",
			"apiVersion": "2018-06-01",
			"properties": {
				"activities": [
					{
						"name": "foreach_price_zone",
						"description": "Pipelinen itererar över de 4 olika elpris-zonerna och utför inhämtning av data från APIet för varje zon (med 2 sekunders paus mellan requests) och lägger in data i data lake.",
						"type": "ForEach",
						"dependsOn": [],
						"userProperties": [],
						"typeProperties": {
							"items": {
								"value": "@createArray('SE1','SE2','SE3','SE4')",
								"type": "Expression"
							},
							"isSequential": false,
							"activities": [
								{
									"name": "ingest_and_copy_prices_to_datalake",
									"description": "Hämtar data från API och lagrar i datalake.",
									"type": "Copy",
									"dependsOn": [],
									"policy": {
										"timeout": "0.12:00:00",
										"retry": 0,
										"retryIntervalInSeconds": 30,
										"secureOutput": false,
										"secureInput": false
									},
									"userProperties": [],
									"typeProperties": {
										"source": {
											"type": "RestSource",
											"httpRequestTimeout": "00:01:40",
											"requestInterval": "00.00:00:00.010",
											"requestMethod": "GET",
											"paginationRules": {
												"supportRFC5988": "true"
											}
										},
										"sink": {
											"type": "JsonSink",
											"storeSettings": {
												"type": "AzureBlobFSWriteSettings"
											},
											"formatSettings": {
												"type": "JsonWriteSettings"
											}
										},
										"enableStaging": false
									},
									"inputs": [
										{
											"referenceName": "ds_prices_api",
											"type": "DatasetReference",
											"parameters": {
												"relativePath": {
													"value": "@concat(\n  formatDateTime(utcNow(),'yyyy'),\n  '/',\n  formatDateTime(utcNow(),'MM'),\n  '-',\n  formatDateTime(utcNow(),'dd'),\n  '_',\n  item(),\n  '.json'\n)",
													"type": "Expression"
												}
											}
										}
									],
									"outputs": [
										{
											"referenceName": "ds_prices_raw",
											"type": "DatasetReference",
											"parameters": {
												"folderPath": {
													"value": "@concat(\n  'raw/elpriser/'\n)\n",
													"type": "Expression"
												},
												"fileName": {
													"value": "@concat(\n  'prices_',\n  formatDateTime(addHours(utcNow(), -1), 'yyyyMMdd'),\n  '_',\n  item(),\n  '.json'\n)",
													"type": "Expression"
												}
											}
										}
									]
								}
							]
						}
					}
				],
				"policy": {
					"elapsedTimeMetric": {}
				},
				"annotations": []
			},
			"dependsOn": [
				"[concat(variables('factoryId'), '/datasets/ds_prices_api')]",
				"[concat(variables('factoryId'), '/datasets/ds_prices_raw')]"
			]
		},
		{
			"name": "[concat(parameters('factoryName'), '/pl_load_bronze')]",
			"type": "Microsoft.DataFactory/factories/pipelines",
			"apiVersion": "2018-06-01",
			"properties": {
				"description": "Pipeline som laddar in data från data lake till bronslagret i SQL-databasen. fileName innehåller inhämtning -1 timme eftersom att när inhämtningen görs t.ex. 14:05 så vill man hämta timmen som just passerat, kl 13-14.",
				"activities": [
					{
						"name": "foreach_load_bronze",
						"description": "Pipelinen itererar över de 4 olika elpris-zonerna och utför inhämtning av data från Data lake för varje zon och lägger in data i SQL bronslager.",
						"type": "ForEach",
						"dependsOn": [],
						"userProperties": [],
						"typeProperties": {
							"items": {
								"value": "@createArray('SE1','SE2','SE3','SE4')",
								"type": "Expression"
							},
							"isSequential": true,
							"activities": [
								{
									"name": "copy_and_load_prices_to_bronze_layer_copy1",
									"description": "Kopierar från datalake och matar in i bronslager i SQL.",
									"type": "Copy",
									"dependsOn": [],
									"policy": {
										"timeout": "0.12:00:00",
										"retry": 0,
										"retryIntervalInSeconds": 30,
										"secureOutput": false,
										"secureInput": false
									},
									"userProperties": [],
									"typeProperties": {
										"source": {
											"type": "JsonSource",
											"additionalColumns": [
												{
													"name": "source_file",
													"value": "$$FILENAME"
												}
											],
											"storeSettings": {
												"type": "AzureBlobFSReadSettings",
												"recursive": true,
												"enablePartitionDiscovery": false
											},
											"formatSettings": {
												"type": "JsonReadSettings"
											}
										},
										"sink": {
											"type": "AzureSqlSink",
											"writeBehavior": "upsert",
											"upsertSettings": {
												"useTempDB": true,
												"keys": [
													"time_start",
													"source_file"
												]
											},
											"sqlWriterUseTableLock": false,
											"disableMetricsCollection": false
										},
										"enableStaging": false,
										"translator": {
											"type": "TabularTranslator",
											"mappings": [
												{
													"source": {
														"path": "$['SEK_per_kWh']"
													},
													"sink": {
														"name": "sek_per_kwh",
														"type": "Decimal"
													}
												},
												{
													"source": {
														"path": "$['EUR_per_kWh']"
													},
													"sink": {
														"name": "eur_per_kwh",
														"type": "Decimal"
													}
												},
												{
													"source": {
														"path": "$['EXR']"
													},
													"sink": {
														"name": "exr",
														"type": "Decimal"
													}
												},
												{
													"source": {
														"path": "$['time_start']"
													},
													"sink": {
														"name": "time_start",
														"type": "String"
													}
												},
												{
													"source": {
														"path": "$['time_end']"
													},
													"sink": {
														"name": "time_end",
														"type": "String"
													}
												},
												{
													"source": {
														"path": "$['source_file']"
													},
													"sink": {
														"name": "source_file",
														"type": "String"
													}
												}
											]
										}
									},
									"inputs": [
										{
											"referenceName": "ds_datalake_prices",
											"type": "DatasetReference",
											"parameters": {
												"folderPath": {
													"value": "@concat(\n  'raw/elpriser'\n)",
													"type": "Expression"
												},
												"fileName": {
													"value": "@concat(\n  'prices_',\n  formatDateTime(addHours(utcNow(), -1), 'yyyyMMdd'),\n  '_',\n  item(),\n  '.json'\n)",
													"type": "Expression"
												}
											}
										}
									],
									"outputs": [
										{
											"referenceName": "ds_sql_bronze_load",
											"type": "DatasetReference",
											"parameters": {}
										}
									]
								}
							]
						}
					}
				],
				"policy": {
					"elapsedTimeMetric": {}
				},
				"annotations": []
			},
			"dependsOn": [
				"[concat(variables('factoryId'), '/datasets/ds_datalake_prices')]",
				"[concat(variables('factoryId'), '/datasets/ds_sql_bronze_load')]"
			]
		},
